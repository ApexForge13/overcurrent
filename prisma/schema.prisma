datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════
// VERIFY MODE MODELS
// ═══════════════════════════════════════

model Story {
  id                String   @id @default(cuid())
  slug              String   @unique
  status            String   @default("review")
  publishedAt       DateTime?
  headline          String
  synopsis          String
  confidenceLevel   String
  confidenceNote    String?
  category          String?
  primaryCategory     String?
  secondaryCategories String?
  searchQuery       String
  sourceCount       Int      @default(0)
  countryCount      Int      @default(0)
  regionCount       Int      @default(0)
  consensusScore    Int      @default(0)
  totalCost         Float    @default(0)
  analysisSeconds   Int      @default(0)
  thePattern        String?
  framingSplit      String?   // JSON array
  lobbyData         String?   // JSON — pattern + summary for hero section
  briefingData      String?   // JSON — missed, frames, fact_survival, key_dispute, watch
  vaultData         String?   // JSON — full claims, framings, discrepancies for deep dive
  outletCount       Int       @default(0)
  sourcesFrom       DateTime?
  sourcesTo         DateTime?
  // ── Re-analysis versioning ──
  currentVersion      Int       @default(1)
  lastReanalyzed      DateTime?
  isOngoing           Boolean   @default(false)
  reanalysisStatus    String?   // null | queued | running | review | published
  // ── Predictive signal layer fields (Session 1: additive, no compute yet) ──
  storyClusterId               String?     // FK to StoryCluster — assigned in Session 2
  storyPhase                   String?     // first_wave | development | consolidation | tail (frozen at time of analysis)
  clusterOverride              String?     // 'new' | 'attach' | null — manual override for v2 reruns
  signalCategory               String?     // 9 signal categories (trade_dispute, military_conflict, etc.) — populated by dedicated Haiku classifier in Session 2
  signalCategoryOverriddenBy   String?     // admin email who manually overrode
  signalCategoryOverriddenAt   DateTime?
  // ── Story arc system fields (Session 3) ──
  // Every Story is EXACTLY one analysisType — mutually exclusive at the record level.
  umbrellaArcId                String?     // FK to UmbrellaArc — null for standalone one-offs
  analysisType                 String?     // standalone | umbrella_tagged | new_arc | arc_rerun
  arcLabel                     String?     // short specific descriptor, e.g. "US-Iran Naval Blockade"
  arcImportance                String?     // core | reference (only set when analysisType='new_arc')
  arcPhaseAtCreation           String?     // phase this analysis was designated to cover (first_wave | development | consolidation | tail)
  arcDesignatedAt              DateTime?   // timestamp when this analysis was tagged to the arc/umbrella
  // ── Session 4: geographic extraction ──
  coordinatesJson              Json?       // {swLat, swLng, neLat, neLng} — extracted at publish time via Haiku
  primaryCountry               String?     // ISO 3166-1 alpha-2 — primary geographic locus
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sources           Source[]
  claims            Claim[]
  discrepancies     Discrepancy[]
  omissions         Omission[]
  framings          FramingAnalysis[]
  silences          RegionalSilence[]
  followUps         FollowUpQuestion[]
  costLogs          CostLog[]
  undercurrentReports UndercurrentReport[] @relation("DominantStory")
  debateRounds    DebateRound[]
  socialDrafts    SocialDraft[]
  discourseSnapshots  DiscourseSnapshot[]
  discourseGap        DiscourseGap?
  versions          StoryVersion[]
  // ── Predictive signal relations ──
  storyCluster        StoryCluster?       @relation(fields: [storyClusterId], references: [id], onDelete: SetNull)
  outletAppearances   OutletAppearance[]
  factOmissions       FactOmission[]
  framingTags         FramingTag[]
  predictiveSignals   PredictiveSignal[]
  // ── Story arc system relations ──
  umbrellaArc         UmbrellaArc?        @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  arcPhaseSchedules   ArcPhaseSchedule[]
  advancementScans    ArcAdvancementScan[]
  // ── Session 4 back-relations ──
  entityMentions       EntityMention[]
  qualityReviewCards   QualityReviewCard[]
  publicationRequests  PublicationRequest[] @relation("OriginalStory")
  publishedFromRequest PublicationRequest?  @relation("PublishedStory")

  @@index([status, createdAt])
  @@index([primaryCategory])
  @@index([status, primaryCategory])
  @@index([storyClusterId])
  @@index([signalCategory])
  @@index([umbrellaArcId])
  @@index([analysisType])
}

model Source {
  id              String   @id @default(cuid())
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  url             String
  title           String
  outlet          String
  outletType      String
  country         String
  region          String
  language        String   @default("English")
  politicalLean   String   @default("unknown")
  reliability     String   @default("unknown")
  summary         String?
  publishedAt     DateTime?
  fetchedAt       DateTime @default(now())
  addedInVersion  Int      @default(1)

  @@index([storyId])
}

model Claim {
  id                    String  @id @default(cuid())
  storyId               String
  story                 Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  claim                 String
  confidence            String
  consensusPct          Int     @default(0)
  supportedBy           String
  contradictedBy        String
  notes                 String?
  sortOrder             Int     @default(0)
  addedInVersion        Int     @default(1)
  status                String  @default("active") // active | contradicted | corroborated | retracted
  contradictedInVersion Int?
  contradictionNote     String?
}

model Discrepancy {
  id             String @id @default(cuid())
  storyId        String
  story          Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  issue          String
  sideA          String
  sideB          String
  sourcesA       String
  sourcesB       String
  assessment     String?
  addedInVersion Int    @default(1)
  status         String @default("active") // active | resolved | retracted
}

model Omission {
  id             String @id @default(cuid())
  storyId        String
  story          Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  outletRegion   String
  missing        String
  presentIn      String
  significance   String?
  addedInVersion Int    @default(1)
  status         String @default("active") // active | resolved | retracted
}

model FramingAnalysis {
  id             String  @id @default(cuid())
  storyId        String
  story          Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region         String
  framing        String
  contrastWith   String?
  addedInVersion Int     @default(1)
  status         String  @default("active") // active | superseded | retracted
}

model RegionalSilence {
  id              String  @id @default(cuid())
  storyId         String
  story           Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region          String
  sourcesSearched Int     @default(0)
  possibleReasons String?
  isSignificant   Boolean @default(false)
}

model FollowUpQuestion {
  id        String @id @default(cuid())
  storyId   String
  story     Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  question  String
  sortOrder Int    @default(0)
}

model DebateRound {
  id           String   @id @default(cuid())
  storyId      String
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region       String
  round        Int
  modelName    String
  provider     String
  content      String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  @@index([storyId])
}

model SocialDraft {
  id                   String   @id @default(cuid())
  storyId              String?
  story                Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  undercurrentReportId String?
  undercurrentReport   UndercurrentReport? @relation("UndercurrentSocialDrafts", fields: [undercurrentReportId], references: [id], onDelete: SetNull)
  platform             String
  content              String
  metadata             String?
  editedContent        String?
  status               String   @default("draft")
  scheduledFor         DateTime?
  postedAt             DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([storyId])
  @@index([status])
}

model StoryVersion {
  id                  String   @id @default(cuid())
  storyId             String
  story               Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  versionNumber       Int
  status              String   @default("pending") // pending | approved | rejected
  newSourceCount      Int      @default(0)
  newClaimsAdded      Int      @default(0)
  claimsContradicted  Int      @default(0)
  claimsCorroborated  Int      @default(0)
  changesSummary      String?
  rawSynthesis        String?  // Full archived synthesis JSON
  costUsd             Float    @default(0)
  createdAt           DateTime @default(now())

  @@unique([storyId, versionNumber])
  @@index([storyId])
}

// ═══════════════════════════════════════
// UNDERCURRENT MODE MODELS (v2)
// ═══════════════════════════════════════

model UndercurrentReport {
  id                  String   @id @default(cuid())
  slug                String   @unique
  status              String   @default("review")
  dominantStoryId     String?
  dominantStory       Story?   @relation("DominantStory", fields: [dominantStoryId], references: [id], onDelete: SetNull)
  primaryCategory     String?   @default("undercurrent")
  dominantCategory    String?
  dominantHeadline    String
  dominantDescription String
  dateRangeStart      DateTime
  dateRangeEnd        DateTime
  searchQuery         String
  synopsis            String
  totalCost           Float    @default(0)
  analysisSeconds     Int      @default(0)
  createdAt           DateTime @default(now())
  displacedStories    DisplacedStory[]
  quietActions        QuietAction[]
  timingAnomalies     TimingAnomaly[]
  costLogs            CostLog[]  @relation("UndercurrentCostLogs")
  socialDrafts        SocialDraft[] @relation("UndercurrentSocialDrafts")
}

model DisplacedStory {
  id                  String  @id @default(cuid())
  reportId            String
  report              UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  headline            String
  peakCoverage        String
  dropoffDate         String
  currentCoverage     String
  coverageDropPct     Int
  wasResolved         Boolean @default(false)
  resolutionNote      String?
  significance        String
  sampleSources       String
  sortOrder           Int     @default(0)
}

model QuietAction {
  id              String  @id @default(cuid())
  reportId        String
  report          UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actionType      String
  title           String
  description     String
  date            String
  source          String
  mediaCoverage   String
  significance    String
  sortOrder       Int     @default(0)
}

model TimingAnomaly {
  id              String  @id @default(cuid())
  reportId        String
  report          UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  event           String
  timing          String
  pattern         String
  historicalContext String?
  significance    String
  sortOrder       Int     @default(0)
}

// ═══════════════════════════════════════
// SHARED
// ═══════════════════════════════════════

model DiscourseSnapshot {
  id                String   @id @default(cuid())
  storyId           String
  story             Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  platform          String
  capturedAt        DateTime @default(now())
  totalEngagement   Int      @default(0)
  postCount         Int      @default(0)
  dominantSentiment String?
  dominantFraming   String?
  posts             DiscoursePost[]

  @@index([storyId])
}

model DiscoursePost {
  id              String   @id @default(cuid())
  snapshotId      String
  snapshot        DiscourseSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  platform        String
  url             String?
  author          String?
  authorFollowers Int?
  isVerified      Boolean  @default(false)
  content         String
  subreddit       String?
  hashtags        String?
  upvotes         Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  views           Int?
  framingType     String?
  sentiment       String?
  topComments     String?
  capturedAt      DateTime @default(now())
  sortOrder       Int      @default(0)
}

model DiscourseGap {
  id                    String   @id @default(cuid())
  storyId               String   @unique
  story                 Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mediaDominantFrame    String
  mediaFramePct         Int
  publicDominantFrame   String
  publicFramePct        Int
  gapScore              Int
  gapDirection          String
  gapSummary            String
  publicSurfacedFirst   String?
  mediaIgnoredByPublic  String?
  publicCounterNarrative String?
  createdAt             DateTime @default(now())
}

model CostLog {
  id                  String   @id @default(cuid())
  storyId             String?
  story               Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  undercurrentReportId String?
  undercurrentReport  UndercurrentReport? @relation("UndercurrentCostLogs", fields: [undercurrentReportId], references: [id], onDelete: SetNull)
  model               String
  inputTokens         Int
  outputTokens        Int
  costUsd             Float
  agentType           String
  region              String?
  // ── Session 5: cost-optimization flag telemetry ──
  // Populated only on the agentType='pipeline_savings' summary row written
  // once per analysis. Null on every per-call row. Shape documented in
  // docs/plans/2026-04-19-cost-optimization-layer.md.
  flagBreakdown       Json?
  // True on the summary row when PIPELINE_FORCE_FULL_QUALITY bypassed all five
  // cost-optimization flags for the analysis. Lets telemetry queries
  // separate optimized runs from forced-full baseline runs.
  forceFullQualityActive Boolean @default(false)
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([storyId])
}

// ═══════════════════════════════════════
// NEWSLETTER
// ═══════════════════════════════════════

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  status         String    @default("active")
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
}

// ═══════════════════════════════════════════════════════════════════════════
// PREDICTIVE SIGNAL INFRASTRUCTURE (admin-only; never queried from public routes)
//
// These tables track outlet behavioral patterns, story clustering,
// fact-level omissions, narrative arc reconstruction, and predictive
// signals. All protected by requireAdmin() at the API layer.
//
// Minimum signal thresholds are commented per-field so you know when
// each metric becomes reliable vs. early-accumulation noise.
// ═══════════════════════════════════════════════════════════════════════════

// Parent entity for repeated analyses of the same story.
// Individual `Story` records (analyses) are children of a StoryCluster
// whenever headline similarity + entity overlap thresholds are met.
// MIN_SIGNAL: phase classification works after 1 analysis.
//             Narrative arc needs 3+ analyses spanning different phases.
model StoryCluster {
  id                          String   @id @default(cuid())
  clusterHeadline             String                   // canonical headline from first analysis
  clusterKeywords             String                   // JSON array of entity keywords for matching
  signalCategory              String?                  // auto-classified; may flip between analyses
  // Admin-curated category that survives auto-reclassification passes. When set,
  // aggregation code should prefer this over signalCategory. Populated manually
  // (or via future admin UI) after the cluster reaches a stable pattern.
  canonicalSignalCategory     String?
  firstDetectedAt             DateTime                 // earliest article publication timestamp
  lastUpdatedAt               DateTime @default(now())
  currentPhase                String   @default("first_wave") // first_wave | development | consolidation | tail
  totalAnalysesRun            Int      @default(0)
  isBackfilled                Boolean  @default(false) // true when reconstructed from historical stories
  // ── Step 6: denormalized arc quality cache ──
  // Values: complete | partial | first_wave_only | incomplete | null (for non-arc clusters).
  // Recomputed by runSignalTracking after each new analysis lands in this cluster.
  arcCompleteness             String?
  arcCompletenessComputedAt   DateTime?
  // ── Standing editorial note (April 2026) ──
  // Persistent guidance for all future analyses of this cluster. Read by
  // the quality review agent and injected into the verdict prompt so
  // re-runs can be evaluated against cluster-specific editorial rules
  // (e.g. "never claim zero coverage universally — specialist press exists").
  // Null for most clusters. Admin-set via the /admin/content editor when
  // a repeat kill pattern is identified.
  adminNotes                  String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  analyses                    Story[]
  narrativeArc                NarrativeArc?
  predictiveSignals           PredictiveSignal[]
  outletAppearances           OutletAppearance[]
  factOmissions               FactOmission[]
  framingTags                 FramingTag[]
  rawSignals                  RawSignalLayer[]
  rawSignalQueue              RawSignalQueue[]
  caseStudyEntries            CaseStudyEntry[]
  // ── Session 4 back-relations ──
  socialSignals               SocialSignal[]
  arcTimelineEvents           ArcTimelineEvent[]

  @@index([currentPhase])
  @@index([signalCategory])
  @@index([canonicalSignalCategory])
  @@index([arcCompleteness])
  @@index([firstDetectedAt])
}

// Canonical outlet record in the signal layer.
// Seeded from src/data/outlets.ts via mapOutlet() function.
// Uses snake_case regions and editorial type enum (differs from OutletInfo).
// Tier is manually assignable via admin UI; default pre-seeded by heuristic.
// MIN_SIGNAL: tier defaults to "unclassified" until manually assigned.
model Outlet {
  id              String   @id @default(cuid())
  domain          String   @unique              // normalized (no www., no protocol)
  name            String
  country         String                        // ISO 3166-1 alpha-2
  region          String                        // snake_case: north_america, europe, asia_pacific, middle_east, africa, latin_america, global
  editorialType   String                        // mainstream | independent | state | wire | aggregator
  politicalLean   String
  reliability     String
  language        String   @default("en")
  tier            String   @default("unclassified") // wire_service | national | regional | specialty | emerging | unclassified
  priority        String?                       // must-have | high | standard (mirror of OutletInfo.priority)
  tierOverriddenBy  String?                     // admin email who manually overrode tier
  tierOverriddenAt  DateTime?
  // ── Session 4: entity link ──
  entityId        String?                       // FK to Entity — null when outlet has no canonical entity record
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  entity          Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  appearances     OutletAppearance[]
  fingerprint     OutletFingerprint?

  @@index([tier])
  @@index([region])
  @@index([editorialType])
  @@index([entityId])
}

// Aggregated behavioral fingerprint per outlet.
// Recomputed periodically from OutletAppearance rows.
// All percentage fields are JSON-encoded for category/dimension breakdowns.
// MIN_SIGNAL: 20 appearances before percentages are reliable.
//             Below 20 → show in admin with "Insufficient Data — X/20" badge.
model OutletFingerprint {
  id                              String   @id @default(cuid())
  outletId                        String   @unique
  outlet                          Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade)
  totalAppearances                Int      @default(0)
  primaryFramingDistribution      String?  // JSON {category: {framing: pct}}
  sourceTypePreference            String?  // JSON {government: pct, expert: pct, unnamed: pct, other: pct}
  regionalOriginBias              String?  // JSON {region: {as_origin: count, as_recipient: count}}
  omissionRate                    Float    @default(0) // pct of 60%+ facts this outlet misses
  pickupSpeed                     String?  // JSON {category: avg_hours_from_first_detection}
  storyCategoryCoverage           String?  // JSON {category: count}
  includesBackfilledData          Boolean  @default(false) // true if any backfilled appearances contributed
  lastComputedAt                  DateTime @default(now())
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

// Event log — one row per outlet per analysis.
// Immutable observational record. Drives fingerprint aggregation.
// onDelete: SetNull on both Story and Outlet so we preserve history even if source records are deleted.
// MIN_SIGNAL: no threshold — every appearance is valid data.
model OutletAppearance {
  id                       String   @id @default(cuid())
  outletId                 String?
  outlet                   Outlet?  @relation(fields: [outletId], references: [id], onDelete: SetNull)
  outletDomain             String                       // denormalized for query speed + survives outlet deletion
  storyId                  String?
  story                    Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyClusterId           String?
  storyCluster             StoryCluster? @relation(fields: [storyClusterId], references: [id], onDelete: SetNull)
  signalCategory           String?
  storyPhase               String                       // phase at time of this analysis
  framingAngle             String?                      // economic | political | humanitarian | security | legal
  wasLeadingFraming        Boolean  @default(false)     // did this outlet lead with this frame
  sourceTypes              String?                      // JSON array of source types cited
  publishedAt              DateTime?                    // article publication timestamp
  hoursFromFirstDetection  Float?                       // pickup speed for this analysis
  isBackfilled             Boolean  @default(false)
  createdAt                DateTime @default(now())

  @@index([outletId, createdAt])
  @@index([storyClusterId])
  @@index([storyId])
  @@index([signalCategory, storyPhase])
}

// Fact-level omission tracking. Distinct from the existing Omission table
// (which tracks regional/outlet gaps). This is a structured, outlet-linked
// record used by the predictive signal layer.
// MIN_SIGNAL: requires 5+ sources covering the story to detect meaningful omission.
model FactOmission {
  id                String   @id @default(cuid())
  storyId           String?
  story             Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyClusterId    String?
  storyCluster      StoryCluster? @relation(fields: [storyClusterId], references: [id], onDelete: SetNull)
  factType          String                       // financial_detail | legal_finding | named_individual | government_statement | historical_context | casualty_figure
  factDescription   String                       // the actual fact being tracked
  presentInPct      Float                        // % of sources that contained this fact
  carriedByOutlets  String                       // JSON array of outlet domains that included it
  missedByOutlets   String                       // JSON array of outlet domains that covered the story but omitted this fact
  storyPhase        String
  isBackfilled      Boolean  @default(false)
  detectedAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([storyClusterId, factType])
  @@index([storyId])
  @@index([factType])
}

// Per-outlet framing snapshot per analysis. Powers narrative arc reconstruction.
// Lightweight — just captures "outlet X led with framing Y in phase Z".
// MIN_SIGNAL: 3+ analyses in a cluster before arc generation considers these.
model FramingTag {
  id               String   @id @default(cuid())
  storyId          String?
  story            Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyClusterId   String?
  storyCluster     StoryCluster? @relation(fields: [storyClusterId], references: [id], onDelete: SetNull)
  outletDomain     String                       // denormalized
  framingAngle     String                       // economic | political | humanitarian | security | legal | other
  isDominant       Boolean  @default(false)     // was this the leading framing in the analysis
  storyPhase       String
  isBackfilled     Boolean  @default(false)
  detectedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([storyClusterId, storyPhase])
  @@index([outletDomain])
}

// 1:1 with StoryCluster — auto-generated view when cluster has 3+ analyses
// spanning at least 2 phases. Regenerates on cluster updates.
// MIN_SIGNAL: 3+ analyses across different phases.
model NarrativeArc {
  id                    String   @id @default(cuid())
  storyClusterId        String   @unique
  storyCluster          StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  firstWaveFramings     String                   // JSON array of framings present at first wave
  persistentFramings    String                   // JSON array — framings that survived to consolidation
  emergentFramings      String                   // JSON array — framings that appeared in development
  surfacedOmissions     String                   // JSON: [{factOmissionId, firstSurfacedByTier, firstSurfacedAt}]
  earlyMovers           String                   // JSON {framingAngle: [outletDomain]}
  lateFollowers         String                   // JSON {framingAngle: [outletDomain]}
  generatedAt           DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Predictive trajectory score computed on each first-wave analysis.
// Only shown in admin UI if CategoryEnablement.enabled is true for that category.
// MIN_SIGNAL: 5+ prior analyses in the same signalCategory for confidence ≥40%.
//             Below threshold → label "Insufficient Data" in admin.
model PredictiveSignal {
  id                           String   @id @default(cuid())
  storyId                      String?
  story                        Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  storyClusterId               String
  storyCluster                 StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  predictedDominantFraming     String
  framingConfidencePct         Int                          // 0-100
  topOmissionRisks             String                       // JSON: [{factType, likelyMissedBy[], likelyCarriedBy[]}]
  momentumFlag                 String                       // stable | shifting | contested
  momentumReason               String
  computedFromAnalysesCount    Int                          // how many prior analyses supported the pattern
  // Step 6: arc quality breakdown feeding the data-quality banner in admin UI.
  // JSON shape: { complete: N, partial: N, first_wave_only: N, incomplete: N,
  //               skippedPhases: N, contributingArcIds: [...], umbrellas: [{id,name,arcCompleteness}] }
  // When complete < 5 the UI surfaces an "Insufficient Data" badge regardless
  // of framingConfidencePct.
  contributingArcsBreakdown    String?
  generatedAt                  DateTime @default(now())
  createdAt                    DateTime @default(now())

  @@index([storyClusterId])
  @@index([storyId])
}

// Per-category aggregation — auto-computed evidence library.
// This is the compounding asset: "Across N diplomatic-negotiation analyses,
// legal details are absent from 73% of First Wave wire coverage."
// MIN_SIGNAL: 10+ analyses in category for meaningful evidence claims.
model StoryCategoryPattern {
  id                              String   @id @default(cuid())
  signalCategory                  String   @unique
  avgAnalysesUntilStabilization   Float    @default(0)       // avg # of analyses before framing stabilizes
  commonFirstWaveOmissions        String?                     // JSON {factType: count}
  leadingTiers                    String?                     // JSON {tier: lead_rate}
  followingTiers                  String?                     // JSON {tier: follow_rate}
  originatingRegions              String?                     // JSON {region: count}
  amplifyingRegions               String?                     // JSON {region: count}
  totalAnalyses                   Int      @default(0)
  lastComputedAt                  DateTime @default(now())
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

// Per-category toggle for surfacing predictive signals in admin UI.
// Manually flipped by admin once signal is validated for that category.
model CategoryEnablement {
  signalCategory   String   @id
  enabled          Boolean  @default(false)
  enabledAt        DateTime?
  enabledBy        String?                     // admin email
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════
// STORY ARC MANAGEMENT SYSTEM (Session 3 — 4-layer architecture)
//
// Layer 1: UmbrellaArc   — named folder grouping related story arcs + one-offs.
//                          Never directly analyzed. Pure container.
// Layer 2: Story Arc     — a Story record with analysisType='new_arc' or 'arc_rerun'
//                          that is bounded to a specific event. Runs on a phase schedule.
// Layer 3: Umbrella-tagged one-off — Story with analysisType='umbrella_tagged'
//                          filed under an umbrella but no re-run schedule.
// Layer 4: Standalone one-off — Story with analysisType='standalone', no umbrella.
//
// All new tables admin-only. Public routes never import them.
// ═══════════════════════════════════════════════════════════════════════════

// Parent container. Never analyzed directly — it's a named folder/project context
// that groups related story arcs and one-offs for cross-event fingerprinting and
// narrative-drift tracking.
// MIN_SIGNAL: cross-event patterns require 3+ nested analyses. Below that the
//             detail page shows "Cross-event patterns require 3 analyses —
//             currently at X of 3" instead of pattern computations.
model UmbrellaArc {
  id                        String   @id @default(cuid())
  name                      String                        // e.g. "US-Iran Escalation 2026"
  description               String?
  status                    String   @default("active")   // active | archived
  signalCategory            String                        // one of the 9 SIGNAL_CATEGORIES
  // Reserved for future sub-umbrella hierarchy, do not build against this field
  // until explicitly instructed.
  parentUmbrellaId          String?
  parentUmbrella            UmbrellaArc?  @relation("UmbrellaHierarchy", fields: [parentUmbrellaId], references: [id], onDelete: SetNull)
  childUmbrellas            UmbrellaArc[] @relation("UmbrellaHierarchy")
  // Scan cadence for the intelligence scan (Step 4). Default manual.
  scanFrequency             String   @default("manual")   // manual | daily | every_48_hours | weekly
  // Auto-populated by signal tracking when a nested analysis runs.
  firstAnalysisAt           DateTime?
  lastAnalysisAt            DateTime?
  totalAnalyses             Int      @default(0)
  storyArcCount             Int      @default(0)          // count of Story records with analysisType='new_arc'
  oneOffCount               Int      @default(0)          // count of umbrella_tagged + standalone-under-umbrella
  intelligenceScanLastRunAt DateTime?
  notes                     String?                       // manual cross-event observations; feeds internal case study library
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  analyses                  Story[]
  intelligenceScans         UmbrellaIntelligenceScan[]
  advancementScans          ArcAdvancementScan[]
  outletProfiles            OutletUmbrellaProfile[]
  phaseSchedules            ArcPhaseSchedule[]
  rawSignals                RawSignalLayer[]
  rawSignalQueue            RawSignalQueue[]
  caseStudyEntries          CaseStudyEntry[]
  // ── Session 4 back-relations ──
  socialSignals                SocialSignal[]
  arcTimelineEvents            ArcTimelineEvent[]
  historicalSatelliteBaselines HistoricalSatelliteBaseline[]

  @@index([status])
  @@index([signalCategory])
  @@index([parentUmbrellaId])
}

// Re-analysis schedule for a single story arc (a Story with analysisType='new_arc').
// Created automatically when a new arc is designated; chained forward as phases complete.
// MIN_SIGNAL: arc completeness scores below 2 completed phases produce unreliable signal.
//             Confidence scores should not display above 40% until at least 3 phases
//             are completed for the parent arc.
model ArcPhaseSchedule {
  id              String   @id @default(cuid())
  storyArcId      String?                      // FK to the initiating Story record
  storyArc        Story?   @relation(fields: [storyArcId], references: [id], onDelete: SetNull)
  umbrellaArcId   String?
  umbrellaArc     UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  targetPhase     String                       // first_wave | development | consolidation | tail
  scheduledFor    DateTime
  status          String   @default("pending") // pending | completed | skipped
  completedAt     DateTime?
  completedByStoryId String?                   // the re-analysis Story that closed this schedule
  skipReason      String?
  isSkipped       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledFor])
  @@index([storyArcId])
  @@index([umbrellaArcId])
}

// One row per intelligence scan. The scan is a lightweight Haiku call
// (~$0.01-$0.03) that surfaces sub-event candidates under an umbrella.
// Does NOT ingest articles. Does NOT run the debate pipeline. Recommendations
// only — nothing auto-executes.
// MIN_SIGNAL: scan recommendations are early signal only below 5 accumulated
//             analyses under the umbrella. UI shows "Early Signal — Limited Data"
//             badge until that threshold.
model UmbrellaIntelligenceScan {
  id                       String   @id @default(cuid())
  umbrellaArcId            String
  umbrellaArc              UmbrellaArc @relation(fields: [umbrellaArcId], references: [id], onDelete: Cascade)
  ranAt                    DateTime @default(now())
  recommendationsGenerated Int      @default(0)
  recommendationsTriggered Int      @default(0)
  rawOutput                String                        // JSON: [{label, kind: 'story_arc'|'one_off', rationale, estimatedPhase}]
  createdAt                DateTime @default(now())

  @@index([umbrellaArcId, ranAt])
}

// Lightweight Haiku scan per active core story arc. Detects whether a story has
// materially advanced since its most recent analysis. Medium+ confidence
// detections surface as notification banners on /admin/signals/arc-queue.
// MIN_SIGNAL: advancement detection confidence below medium must NEVER surface
//             a UI notification. Low-confidence scans are logged here but
//             silently discarded from the admin-facing UI.
model ArcAdvancementScan {
  id                  String   @id @default(cuid())
  storyArcId          String
  storyArc            Story    @relation(fields: [storyArcId], references: [id], onDelete: Cascade)
  umbrellaArcId       String
  umbrellaArc         UmbrellaArc @relation(fields: [umbrellaArcId], references: [id], onDelete: Cascade)
  scannedAt           DateTime @default(now())
  advancementDetected Boolean  @default(false)
  confidenceLevel     String                         // low | medium | high
  rationale           String?
  triggeredAnalysis   Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([advancementDetected, confidenceLevel])
  @@index([storyArcId, scannedAt])
  @@index([umbrellaArcId])
}

// Cross-event outlet behavior profile scoped to a single umbrella.
// Recomputed whenever a new analysis is added to the umbrella.
// MIN_SIGNAL: frameConsistency requires minimum 5 appearances within the
//             umbrella before the percentage is statistically meaningful.
//             Below threshold the admin UI shows "Insufficient Data" badge.
//             Section itself does not render until 3+ umbrella-level analyses exist.
model OutletUmbrellaProfile {
  id                       String   @id @default(cuid())
  outletId                 String
  umbrellaArcId            String
  umbrellaArc              UmbrellaArc @relation(fields: [umbrellaArcId], references: [id], onDelete: Cascade)
  frameConsistency         Float    @default(0) // pct of events where outlet led with same primary framing angle
  earlyMoverRate           Float    @default(0) // pct of events where First Wave framing became dominant Consolidation frame
  omissionConsistencyRate  Float    @default(0) // pct of events where omission pattern matched outlet's overall fingerprint for this signalCategory
  analysesAppeared         Int      @default(0)
  computedAt               DateTime @default(now())
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([outletId, umbrellaArcId])
  @@index([umbrellaArcId])
}

// ═══════════════════════════════════════
// RAW SIGNAL LAYER (Session 4)
// ═══════════════════════════════════════
// External data sources that cross-reference against narrative coverage.
// Every integration writes to RawSignalLayer. The queue (RawSignalQueue) is
// the audit trail of every source activation — trigger layer, reason, status.
// CaseStudyEntry auto-populates when an admin reviews a finding, building
// the internal evidence library for enterprise sales.
//
// ADMIN-ONLY. Never surfaced on public-facing pages. All three tables are
// guarded by requireAdmin() at the API layer. Public isolation CI test
// includes all three.

// Single raw signal observation from an external data source.
// Writes happen async, non-blocking from main pipeline.
// divergenceFlag is the key column — raised when raw data contradicts or
// materially adds to narrative coverage.
model RawSignalLayer {
  id                   String   @id @default(cuid())
  storyClusterId       String
  storyCluster         StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  umbrellaArcId        String?
  umbrellaArc          UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  signalType           String                     // gdelt | maritime_ais | aviation_adsb | sec_filing | ... (see lib/raw-signals/types.ts)
  signalSource         String                     // specific provider: "sentinel-hub", "opensky", "marinetraffic", etc.
  captureDate          DateTime                   // when the signal was captured (may predate pipeline run)
  coordinates          Json?                      // bounding box { swLat, swLng, neLat, neLng } — extracted per-integration via Haiku
  rawContent           Json                       // structured data from the source
  haikuSummary         String                     // plain-language description of what the raw signal shows
  divergenceFlag       Boolean  @default(false)   // true when raw data contradicts/adds to narrative
  divergenceDescription String?                   // 1-2 sentences describing the specific divergence
  confidenceLevel      String   @default("low")   // low | medium | high
  reviewedByAdmin      Boolean  @default(false)
  adminNotes           String?
  caseStudyEntries     CaseStudyEntry[]
  entitySignalEntries  EntitySignalIndex[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([storyClusterId])
  @@index([signalType])
  @@index([divergenceFlag])
  @@index([reviewedByAdmin])
  @@index([umbrellaArcId])
}

// Queue of pending/running/completed signal enrichment jobs.
// Every source activation is auditable: triggerLayer and triggerReason
// record exactly why a source was pulled for this cluster.
// status 'requires_approval' is reserved for gated integrations (PACER).
model RawSignalQueue {
  id                    String   @id @default(cuid())
  storyClusterId        String
  storyCluster          StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  umbrellaArcId         String?
  umbrellaArc           UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  signalType            String
  triggerLayer          String                    // category_trigger | entity_trigger | keyword_trigger
  triggerReason         String                    // which category/entity/keyword triggered this source
  status                String   @default("pending") // pending | running | completed | skipped | failed | requires_approval
  approvedByAdmin       Boolean  @default(false)
  approvalRequestedAt   DateTime?
  approvedAt            DateTime?
  approvedOrDeniedBy    String?
  estimatedCost         Float?
  actualCost            Float?
  dismissalReason       String?
  recapContribution     Boolean  @default(true)   // for PACER: contribute pulled doc to RECAP archive
  resultSignalLayerId   String?                   // FK to RawSignalLayer once completed
  errorMessage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([storyClusterId])
  @@index([status])
  @@index([signalType])
  @@index([approvedByAdmin])
}

// Case study archive — internal evidence library for enterprise sales.
// Auto-populates when an admin marks a RawSignalLayer record reviewed with
// adminNotes. isPublishable is manually toggled when a finding is clean
// enough to share externally.
model CaseStudyEntry {
  id                  String   @id @default(cuid())
  rawSignalLayerId    String?
  rawSignalLayer      RawSignalLayer? @relation(fields: [rawSignalLayerId], references: [id], onDelete: SetNull)
  storyClusterId      String
  storyCluster        StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  umbrellaArcId       String?
  umbrellaArc         UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  signalType          String
  headline            String
  fullDescription     String
  storyPhaseAtDetection String                    // first_wave | development | consolidation | tail
  divergenceType      String                     // narrative_contradicts_raw | narrative_omits_raw | raw_precedes_narrative | raw_corroborates_narrative
  isPublishable       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([storyClusterId])
  @@index([umbrellaArcId])
  @@index([signalType])
  @@index([isPublishable])
  @@index([divergenceType])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 4 — SUBSCRIPTIONS & BILLING (System F)
//
// New tables only. Does NOT modify the existing email gate (email_captures +
// client-side localStorage) — unauth users and authenticated-without-
// subscription users are both treated as "free" tier by UserPermissions.
// Full credit consumption tracking (CreditBalance, CreditLedger, overage
// billing) lands in Phase 22 — this phase only persists who has what tier.
// ═══════════════════════════════════════════════════════════════════════════

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique        // Supabase auth user id
  userEmail            String                  // denormalized for admin display
  tier                 String   @default("free") // free | consumer_paid | b2b_researcher | b2b_organization | enterprise_small | enterprise_mid | enterprise_large | enterprise_trophy
  status               String   @default("active") // active | past_due | canceled | trialing | incomplete | incomplete_expired | unpaid
  stripeCustomerId     String?                 // cus_XXX
  stripeSubscriptionId String?  @unique        // sub_XXX
  stripePriceId        String?                 // price_XXX — monthly vs annual variant
  billingInterval      String?                 // month | year | null (enterprise / free)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean  @default(false)
  canceledAt           DateTime?
  // ── Consumer tier one-time signup bonus ──
  // Consumer paid ($14.99 founding / $19.99 standard) includes exactly one
  // free analysis credit granted on subscription.created, non-recurring.
  // After this single run, further analyses are billed at cost+50% overage.
  // B2B tiers never set this flag — they get monthly_credits_usd allocations instead.
  signupBonusGranted   Boolean  @default(false)
  signupBonusGrantedAt DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([tier, status])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — ENTITY INTELLIGENCE LAYER (System G)
// ═══════════════════════════════════════════════════════════════════════════

model Entity {
  id             String   @id @default(cuid())
  name           String
  type           String                       // person | organization | location | vessel | country | company
  signalCategory String?
  slug           String   @unique
  description    String?
  isPublic       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  mentions       EntityMention[]
  signalIndex    EntitySignalIndex[]
  tickerMappings TickerEntityMap[]
  outlets        Outlet[]
  socialSignals  SocialSignal[]
  monitoredBy    MonitoredEntity[]
  historicalEquityBaselines HistoricalEquityBaseline[]

  @@index([slug])
  @@index([name])
  @@index([type])
}

model EntityMention {
  id             String   @id @default(cuid())
  entityId       String
  entity         Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  storyId        String
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mentionContext String
  createdAt      DateTime @default(now())

  @@index([entityId])
  @@index([storyId])
}

model EntitySignalIndex {
  id               String   @id @default(cuid())
  entityId         String
  entity           Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  signalType       String
  rawSignalLayerId String?
  rawSignalLayer   RawSignalLayer? @relation(fields: [rawSignalLayerId], references: [id], onDelete: SetNull)
  signalDate       DateTime
  signalSummary    String
  sourceUrl        String?
  confidenceLevel  String   @default("low")   // low | medium | high
  createdAt        DateTime @default(now())

  @@index([entityId])
  @@index([signalType])
  @@index([signalDate])
}

model TickerEntityMap {
  id           String   @id @default(cuid())
  ticker       String   @unique
  entityId     String
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  exchangeName String
  createdAt    DateTime @default(now())

  @@index([entityId])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — KNOWLEDGE GRAPH (System D)
// Admin-only. streamType tags every node: narrative | ground_truth | psychological.
// ═══════════════════════════════════════════════════════════════════════════

model GraphNode {
  id            String   @id @default(cuid())
  nodeType      String                         // story_cluster | outlet | entity | raw_signal | umbrella_arc | data_source | signal_category | geographic_region | social_signal
  nodeLabel     String
  nodeWeight    Float    @default(1.0)
  metadata      Json
  streamType    String?                        // narrative | ground_truth | psychological
  createdAt     DateTime @default(now())
  outgoingEdges GraphEdge[] @relation("SourceNode")
  incomingEdges GraphEdge[] @relation("TargetNode")

  @@index([nodeType])
  @@index([nodeLabel])
  @@index([streamType])
}

model GraphEdge {
  id                     String   @id @default(cuid())
  sourceNodeId           String
  sourceNode             GraphNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId           String
  targetNode             GraphNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  edgeType               String                  // mentions | corroborates | contradicts | precedes | follows | contains | fingerprint_match | entity_match | geographic_overlap | temporal_proximity
  edgeWeight             Float
  temporalProximityHours Int?
  createdAt              DateTime @default(now())

  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([edgeType])
  @@index([edgeWeight])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — ALERTS (System C)
// ═══════════════════════════════════════════════════════════════════════════

model AlertMonitor {
  id                    String   @id @default(cuid())
  userId                String
  monitorType           String                   // entity | outlet | category | region | keyword | ticker
  monitorValue          String
  notificationFrequency String   @default("daily") // realtime | daily | weekly
  lastFiredAt           DateTime?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())

  @@index([userId])
  @@index([monitorType])
  @@index([isActive])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — B2B USAGE, QUALITY REVIEW, PUBLICATION (Systems E, F)
// ═══════════════════════════════════════════════════════════════════════════

model B2BUsageRecord {
  id             String   @id @default(cuid())
  accountId      String
  storyId        String
  apiCostClaude  Float
  apiCostHaiku   Float
  rawSignalCosts Json
  totalCost      Float
  markup         Float
  billedAmount   Float
  createdAt      DateTime @default(now())

  @@index([accountId])
  @@index([storyId])
  @@index([createdAt])
}

model QualityReviewCard {
  id                      String   @id @default(cuid())
  storyId                 String
  story                   Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  overallRecommendation   String                 // approved | approved_with_edits | hold | kill
  verificationSummary     Json
  patternVerified         Boolean  @default(false)
  patternStressTestDetail String
  editorialScores         Json
  sensitivityFlags        Json
  suggestedEdits          String?
  reviewCost              Float
  reviewDurationSeconds   Int
  webSearchesRun          Int
  createdAt               DateTime @default(now())

  @@index([storyId])
  @@index([overallRecommendation])
}

model PublicationRequest {
  id                    String   @id @default(cuid())
  b2bAccountId          String
  storyId               String
  story                 Story    @relation("OriginalStory", fields: [storyId], references: [id], onDelete: Cascade)
  requestedAt           DateTime @default(now())
  attributionPreference String                   // attributed | anonymous | do_not_publish
  status                String   @default("pending") // pending | approved | declined
  reviewedAt            DateTime?
  reviewedBy            String?
  publishedStoryId      String?  @unique
  publishedStory        Story?   @relation("PublishedStory", fields: [publishedStoryId], references: [id], onDelete: SetNull)
  createdAt             DateTime @default(now())

  @@index([b2bAccountId])
  @@index([status])
  @@index([storyId])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — ENTERPRISE ACCOUNTS + DEPLOYMENT (System H)
// ClientNamespace <-> EnterpriseAccount is 1:1 via @unique on namespace side
// (single FK cleaner than bidirectional — approved in Phase 1 checkpoint).
// ═══════════════════════════════════════════════════════════════════════════

model EnterpriseAccount {
  id                        String   @id @default(cuid())
  organizationName          String
  contactName               String
  contactEmail              String
  monthlyRate               Float
  contractStartDate         DateTime
  contractEndDate           DateTime
  ndaSigned                 Boolean  @default(false)
  features                  Json
  dataResidencyModel        String   @default("api_only") // api_only | private_namespace | hybrid | onpremise
  allowsClientDataIngestion Boolean  @default(false)
  deploymentFingerprint     String?
  licenseKey                String?  @unique
  licenseScope              Json?
  notes                     String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  clientNamespace           ClientNamespace?
  outputTemplates           ClientOutputTemplate[]
  monitoredPortfolios       MonitoredPortfolio[]
  monitoredEntities         MonitoredEntity[]
  monitoringScans           MonitoringScan[]
  intelligenceBriefs        IntelligenceBrief[]

  @@index([organizationName])
  @@index([contractEndDate])
}

model ClientNamespace {
  id                   String   @id @default(cuid())
  enterpriseAccountId  String   @unique
  enterpriseAccount    EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  namespaceName        String
  storageQuotaGb       Int      @default(0)
  dataIngestionEnabled Boolean  @default(false)
  telemetryOptIn       Boolean  @default(false)
  createdAt            DateTime @default(now())
}

model ClientOutputTemplate {
  id                  String   @id @default(cuid())
  enterpriseAccountId String
  enterpriseAccount   EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  templateName        String
  outputFormat        String                 // trading_desk_brief | policy_memo | crisis_comms | analyst_report | executive_summary | custom
  templateConfig      Json
  createdAt           DateTime @default(now())

  @@index([enterpriseAccountId])
}

model DataLicense {
  id                            String   @id @default(cuid())
  organizationName              String
  licenseType                   String                 // fingerprint_library | framing_archive | arc_database | full_dataset | api_feed
  annualRate                    Float
  startDate                     DateTime
  endDate                       DateTime
  dataDeliveryMethod            String                 // api | bulk_export | isolated_deployment | both
  usageRestrictions             String
  reverseEngineeringProhibition Boolean  @default(true)
  extractionProhibition         Boolean  @default(true)
  auditRightRetained            Boolean  @default(true)
  killSwitchProvision           Boolean  @default(true)
  createdAt                     DateTime @default(now())

  @@index([endDate])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — HISTORICAL BACKFILL (System B)
// NON-NEGOTIABLE RULE: isHistoricalBackfill defaults to true on all three
// Historical* tables. Historical data NEVER feeds trajectory scores,
// momentum flags, or predictive confidence percentages. Enforced in every
// fingerprint aggregation and pattern library function.
// ═══════════════════════════════════════════════════════════════════════════

// HistoricalSpendingBaseline — USASpending.gov two-year backfill.
// NEVER feeds trajectory scores, momentum flags, or predictive confidence percentages.
model HistoricalSpendingBaseline {
  id                   String   @id @default(cuid())
  awardee              String
  amount               Float
  agency               String
  awardDate            DateTime
  description          String
  isHistoricalBackfill Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([awardee])
  @@index([agency])
  @@index([awardDate])
}

// HistoricalEquityBaseline — Polygon EOD OHLCV backfill (Phase 10 populates).
// NEVER feeds trajectory scores, momentum flags, or predictive confidence percentages.
model HistoricalEquityBaseline {
  id                   String   @id @default(cuid())
  ticker               String
  entityId             String?
  entity               Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  date                 DateTime
  open                 Float
  high                 Float
  low                  Float
  close                Float
  volume               BigInt
  isHistoricalBackfill Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([ticker, date])
  @@index([entityId])
}

// HistoricalSatelliteBaseline — Sentinel Hub twelve-month imagery per active umbrella region.
// NEVER feeds trajectory scores, momentum flags, or predictive confidence percentages.
model HistoricalSatelliteBaseline {
  id                   String   @id @default(cuid())
  umbrellaArcId        String?
  umbrellaArc          UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  coordinates          Json
  captureDate          DateTime
  imageDescription     String
  cloudCoverPct        Float?
  isHistoricalBackfill Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([umbrellaArcId])
  @@index([captureDate])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — SOCIAL LAYER — STREAM 3 (System I)
// Unfiltered psychological signals. credibilityScore + isVerifiedOfficial
// govern weighting. Never surface unverified social as primary finding
// without Stream 1 or Stream 2 corroboration.
// ═══════════════════════════════════════════════════════════════════════════

model SocialChannel {
  id                 String   @id @default(cuid())
  platform           String                 // twitter | telegram | reddit | wechat | linkedin
  channelIdentifier  String
  channelName        String
  region             String?
  signalCategories   String[]
  followerCount      Int?
  credibilityScore   Float    @default(0.5)
  isVerifiedOfficial Boolean  @default(false)
  lastCrawledAt      DateTime?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  socialSignals      SocialSignal[]

  @@unique([platform, channelIdentifier])
  @@index([platform])
  @@index([region])
  @@index([isActive])
}

model SocialSignal {
  id                    String   @id @default(cuid())
  socialChannelId       String
  socialChannel         SocialChannel @relation(fields: [socialChannelId], references: [id], onDelete: Cascade)
  storyClusterId        String?
  storyCluster          StoryCluster? @relation(fields: [storyClusterId], references: [id], onDelete: SetNull)
  umbrellaArcId         String?
  umbrellaArc           UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  entityId              String?
  entity                Entity?  @relation(fields: [entityId], references: [id], onDelete: SetNull)
  postUrl               String
  postContent           String
  postDate              DateTime
  engagementCount       Int?
  engagementVelocity    Float?
  language              String
  translatedContent     String?
  sentimentScore        Float?
  framingAngle          String?
  haikuSummary          String
  divergesFromNarrative Boolean  @default(false)
  divergenceDescription String?
  createdAt             DateTime @default(now())

  @@index([storyClusterId])
  @@index([entityId])
  @@index([socialChannelId])
  @@index([postDate])
  @@index([divergesFromNarrative])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — AMBIENT MONITORING (System J) + INTELLIGENCE BRIEFS (System K)
// ═══════════════════════════════════════════════════════════════════════════

model MonitoredPortfolio {
  id                  String   @id @default(cuid())
  enterpriseAccountId String
  enterpriseAccount   EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  portfolioName       String
  positionData        Json?
  lastSyncedAt        DateTime?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([enterpriseAccountId])
}

model MonitoredEntity {
  id                  String   @id @default(cuid())
  enterpriseAccountId String
  enterpriseAccount   EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  entityId            String
  entity              Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  monitoringIntensity String                 // low | medium | high | critical
  positionSize        Float?
  customContext       String?
  alertThreshold      String   @default("significant_divergence") // any_divergence | significant_divergence | major_divergence
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  monitoringScans     MonitoringScan[]
  intelligenceBriefs  IntelligenceBrief[]

  @@unique([enterpriseAccountId, entityId])
  @@index([enterpriseAccountId])
  @@index([entityId])
  @@index([monitoringIntensity])
}

model MonitoringScan {
  id                       String   @id @default(cuid())
  enterpriseAccountId      String
  enterpriseAccount        EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  monitoredEntityId        String
  monitoredEntity          MonitoredEntity @relation(fields: [monitoredEntityId], references: [id], onDelete: Cascade)
  scanCycle                DateTime
  streamsChecked           String[]
  divergencesFound         Int      @default(0)
  materialDivergencesFound Int      @default(0)
  briefGenerated           Boolean  @default(false)
  briefId                  String?
  brief                    IntelligenceBrief? @relation(fields: [briefId], references: [id], onDelete: SetNull)
  scanDurationMs           Int
  scanCostCents            Int
  createdAt                DateTime @default(now())

  @@index([enterpriseAccountId])
  @@index([scanCycle])
  @@index([materialDivergencesFound])
}

model IntelligenceBrief {
  id                    String   @id @default(cuid())
  enterpriseAccountId   String
  enterpriseAccount     EnterpriseAccount @relation(fields: [enterpriseAccountId], references: [id], onDelete: Cascade)
  monitoredEntityId     String?
  monitoredEntity       MonitoredEntity? @relation(fields: [monitoredEntityId], references: [id], onDelete: SetNull)
  triggeringSignals     Json
  briefType             String                 // portfolio_alert | entity_alert | geographic_alert | category_alert
  urgencyLevel          String                 // informational | notable | significant | critical
  headline              String
  bodyText              String
  narrativeContext      String
  physicalGroundTruth   String
  psychologicalSignal   String?
  priorSimilarCases     Json?
  probabilityAssessment String?
  recommendedActions    String?
  outputFormat          String
  deliveredAt           DateTime?
  readAt                DateTime?
  acknowledgedAt        DateTime?
  createdAt             DateTime @default(now())
  deliveries            BriefDelivery[]
  scans                 MonitoringScan[]

  @@index([enterpriseAccountId])
  @@index([urgencyLevel])
  @@index([deliveredAt])
}

model BriefDelivery {
  id                  String   @id @default(cuid())
  intelligenceBriefId String
  intelligenceBrief   IntelligenceBrief @relation(fields: [intelligenceBriefId], references: [id], onDelete: Cascade)
  deliveryMethod      String                 // email | webhook | in_app | api
  deliveryAddress     String
  deliveredAt         DateTime?
  status              String   @default("pending") // pending | delivered | failed
  failureReason       String?
  createdAt           DateTime @default(now())

  @@index([intelligenceBriefId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════════════════════
// SESSION 4 PHASE 1 — IMMUTABLE ARC TIMELINE (System L)
// Append-only. Nothing ever deleted. Every event from every stream writes here.
// ═══════════════════════════════════════════════════════════════════════════

model ArcTimelineEvent {
  id                    String   @id @default(cuid())
  storyClusterId        String
  storyCluster          StoryCluster @relation(fields: [storyClusterId], references: [id], onDelete: Cascade)
  umbrellaArcId         String?
  umbrellaArc           UmbrellaArc? @relation(fields: [umbrellaArcId], references: [id], onDelete: SetNull)
  eventType             String                 // analysis_run | raw_signal | social_signal | source_surge | outlet_tier_entry | framing_shift | advancement_detection | correction | social_velocity_spike
  eventTimestamp        DateTime
  eventData             Json
  streamType            String                 // narrative | ground_truth | psychological
  isWildFinding         Boolean  @default(false)
  wildFindingPercentile Float?
  isCorrectionEvent     Boolean  @default(false)
  correctionDescription String?
  correctionImpact      String?
  isPublic              Boolean  @default(true)
  createdAt             DateTime @default(now())

  @@index([storyClusterId])
  @@index([eventType])
  @@index([eventTimestamp])
  @@index([isWildFinding])
  @@index([isCorrectionEvent])
}
