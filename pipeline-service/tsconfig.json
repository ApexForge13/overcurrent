{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["server.ts", "../src/lib/**/*", "../src/agents/**/*", "../src/ingestion/**/*", "../src/data/**/*"],
  "exclude": ["node_modules", "../src/app/**/*", "../src/components/**/*"]
}
