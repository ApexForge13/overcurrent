datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ═══════════════════════════════════════
// VERIFY MODE MODELS
// ═══════════════════════════════════════

model Story {
  id                String   @id @default(cuid())
  slug              String   @unique
  status            String   @default("review")
  publishedAt       DateTime?
  headline          String
  synopsis          String
  confidenceLevel   String
  confidenceNote    String?
  category          String?
  primaryCategory     String?
  secondaryCategories String?
  searchQuery       String
  sourceCount       Int      @default(0)
  countryCount      Int      @default(0)
  regionCount       Int      @default(0)
  consensusScore    Int      @default(0)
  totalCost         Float    @default(0)
  analysisSeconds   Int      @default(0)
  thePattern        String?
  framingSplit      String?   // JSON array
  lobbyData         String?   // JSON — pattern + summary for hero section
  briefingData      String?   // JSON — missed, frames, fact_survival, key_dispute, watch
  vaultData         String?   // JSON — full claims, framings, discrepancies for deep dive
  outletCount       Int       @default(0)
  sourcesFrom       DateTime?
  sourcesTo         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sources           Source[]
  claims            Claim[]
  discrepancies     Discrepancy[]
  omissions         Omission[]
  framings          FramingAnalysis[]
  silences          RegionalSilence[]
  followUps         FollowUpQuestion[]
  costLogs          CostLog[]
  undercurrentReports UndercurrentReport[] @relation("DominantStory")
  debateRounds    DebateRound[]
  socialDrafts    SocialDraft[]
  discourseSnapshots  DiscourseSnapshot[]
  discourseGap        DiscourseGap?

  @@index([status, createdAt])
  @@index([primaryCategory])
  @@index([status, primaryCategory])
}

model Source {
  id              String   @id @default(cuid())
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  url             String
  title           String
  outlet          String
  outletType      String
  country         String
  region          String
  language        String   @default("English")
  politicalLean   String   @default("unknown")
  reliability     String   @default("unknown")
  summary         String?
  publishedAt     DateTime?
  fetchedAt       DateTime @default(now())

  @@index([storyId])
}

model Claim {
  id              String  @id @default(cuid())
  storyId         String
  story           Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  claim           String
  confidence      String
  consensusPct    Int     @default(0)
  supportedBy     String
  contradictedBy  String
  notes           String?
  sortOrder       Int     @default(0)
}

model Discrepancy {
  id         String @id @default(cuid())
  storyId    String
  story      Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  issue      String
  sideA      String
  sideB      String
  sourcesA   String
  sourcesB   String
  assessment String?
}

model Omission {
  id           String @id @default(cuid())
  storyId      String
  story        Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  outletRegion String
  missing      String
  presentIn    String
  significance String?
}

model FramingAnalysis {
  id           String  @id @default(cuid())
  storyId      String
  story        Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region       String
  framing      String
  contrastWith String?
}

model RegionalSilence {
  id              String  @id @default(cuid())
  storyId         String
  story           Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region          String
  sourcesSearched Int     @default(0)
  possibleReasons String?
  isSignificant   Boolean @default(false)
}

model FollowUpQuestion {
  id        String @id @default(cuid())
  storyId   String
  story     Story  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  question  String
  sortOrder Int    @default(0)
}

model DebateRound {
  id           String   @id @default(cuid())
  storyId      String
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  region       String
  round        Int
  modelName    String
  provider     String
  content      String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  createdAt    DateTime @default(now())

  @@index([storyId])
}

model SocialDraft {
  id                   String   @id @default(cuid())
  storyId              String?
  story                Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  undercurrentReportId String?
  undercurrentReport   UndercurrentReport? @relation("UndercurrentSocialDrafts", fields: [undercurrentReportId], references: [id], onDelete: SetNull)
  platform             String
  content              String
  metadata             String?
  editedContent        String?
  status               String   @default("draft")
  scheduledFor         DateTime?
  postedAt             DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([storyId])
  @@index([status])
}

// ═══════════════════════════════════════
// UNDERCURRENT MODE MODELS (v2)
// ═══════════════════════════════════════

model UndercurrentReport {
  id                  String   @id @default(cuid())
  slug                String   @unique
  status              String   @default("review")
  dominantStoryId     String?
  dominantStory       Story?   @relation("DominantStory", fields: [dominantStoryId], references: [id], onDelete: SetNull)
  primaryCategory     String?   @default("undercurrent")
  dominantCategory    String?
  dominantHeadline    String
  dominantDescription String
  dateRangeStart      DateTime
  dateRangeEnd        DateTime
  searchQuery         String
  synopsis            String
  totalCost           Float    @default(0)
  analysisSeconds     Int      @default(0)
  createdAt           DateTime @default(now())
  displacedStories    DisplacedStory[]
  quietActions        QuietAction[]
  timingAnomalies     TimingAnomaly[]
  costLogs            CostLog[]  @relation("UndercurrentCostLogs")
  socialDrafts        SocialDraft[] @relation("UndercurrentSocialDrafts")
}

model DisplacedStory {
  id                  String  @id @default(cuid())
  reportId            String
  report              UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  headline            String
  peakCoverage        String
  dropoffDate         String
  currentCoverage     String
  coverageDropPct     Int
  wasResolved         Boolean @default(false)
  resolutionNote      String?
  significance        String
  sampleSources       String
  sortOrder           Int     @default(0)
}

model QuietAction {
  id              String  @id @default(cuid())
  reportId        String
  report          UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actionType      String
  title           String
  description     String
  date            String
  source          String
  mediaCoverage   String
  significance    String
  sortOrder       Int     @default(0)
}

model TimingAnomaly {
  id              String  @id @default(cuid())
  reportId        String
  report          UndercurrentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  event           String
  timing          String
  pattern         String
  historicalContext String?
  significance    String
  sortOrder       Int     @default(0)
}

// ═══════════════════════════════════════
// SHARED
// ═══════════════════════════════════════

model DiscourseSnapshot {
  id                String   @id @default(cuid())
  storyId           String
  story             Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  platform          String
  capturedAt        DateTime @default(now())
  totalEngagement   Int      @default(0)
  postCount         Int      @default(0)
  dominantSentiment String?
  dominantFraming   String?
  posts             DiscoursePost[]

  @@index([storyId])
}

model DiscoursePost {
  id              String   @id @default(cuid())
  snapshotId      String
  snapshot        DiscourseSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  platform        String
  url             String?
  author          String?
  authorFollowers Int?
  isVerified      Boolean  @default(false)
  content         String
  subreddit       String?
  hashtags        String?
  upvotes         Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  views           Int?
  framingType     String?
  sentiment       String?
  topComments     String?
  capturedAt      DateTime @default(now())
  sortOrder       Int      @default(0)
}

model DiscourseGap {
  id                    String   @id @default(cuid())
  storyId               String   @unique
  story                 Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  mediaDominantFrame    String
  mediaFramePct         Int
  publicDominantFrame   String
  publicFramePct        Int
  gapScore              Int
  gapDirection          String
  gapSummary            String
  publicSurfacedFirst   String?
  mediaIgnoredByPublic  String?
  publicCounterNarrative String?
  createdAt             DateTime @default(now())
}

model CostLog {
  id                  String   @id @default(cuid())
  storyId             String?
  story               Story?   @relation(fields: [storyId], references: [id], onDelete: SetNull)
  undercurrentReportId String?
  undercurrentReport  UndercurrentReport? @relation("UndercurrentCostLogs", fields: [undercurrentReportId], references: [id], onDelete: SetNull)
  model               String
  inputTokens         Int
  outputTokens        Int
  costUsd             Float
  agentType           String
  region              String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([storyId])
}

// ═══════════════════════════════════════
// NEWSLETTER
// ═══════════════════════════════════════

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  status         String    @default("active")
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?
}
